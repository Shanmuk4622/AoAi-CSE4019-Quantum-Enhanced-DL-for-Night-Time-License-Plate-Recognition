        <mxCell id="s4_details_bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5C6BC0;arcSize=6;strokeWidth=1.5;" value="" vertex="1">
          <mxGeometry height="250" width="250" x="2310" y="435" as="geometry" />
        </mxCell>
        <mxCell id="s4_details_title" parent="1" style="text;html=1;align=center;" value="&lt;font style=&quot;font-size:10px;color:#283593&quot;&gt;&lt;b&gt;VQC Details&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="18" width="250" x="2310" y="438" as="geometry" />
        </mxCell>
        <mxCell id="s4_details_text" parent="1" style="text;html=1;align=left;" value="&lt;font style=&quot;font-size:9px;color:#333&quot;&gt;• 8 Qubits (Hilbert space ℂ²⁵⁶)&lt;br&gt;• 2 StronglyEntanglingLayers&lt;br&gt;• 48 trainable parameters&lt;br&gt;  &amp;nbsp; (2 layers × 8 qubits × 3 angles)&lt;br&gt;• Embedding: AngleEmbedding (R&lt;sub&gt;X&lt;/sub&gt;)&lt;br&gt;• Entanglement: CNOT (range 1, 2)&lt;br&gt;• Observable: Pauli-Z (per qubit)&lt;br&gt;• Outputs: 8 expectation values&lt;br&gt;• Gradients: Parameter-shift rule&lt;br&gt;• Simulator: default.qubit (cuda:0)&lt;br&gt;• Framework: PennyLane v0.44.1&lt;br&gt;• TorchLayer integration&lt;/font&gt;" vertex="1">
          <mxGeometry height="160" width="235" x="2318" y="460" as="geometry" />
        </mxCell>
        <mxCell id="s4_adv_bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#FBC02D;arcSize=6;strokeWidth=1.5;" value="" vertex="1">
          <mxGeometry height="250" width="250" x="2580" y="435" as="geometry" />
        </mxCell>
        <mxCell id="s4_adv_title" parent="1" style="text;html=1;align=center;" value="&lt;font style=&quot;font-size:10px;color:#F57F17&quot;&gt;&lt;b&gt;VQC Advantages&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="18" width="250" x="2580" y="438" as="geometry" />
        </mxCell>
        <mxCell id="s4_adv_text" parent="1" style="text;html=1;align=left;" value="&lt;font style=&quot;font-size:9px;color:#333&quot;&gt;• Exponential Hilbert Space (2⁸=256)&lt;br&gt;• StronglyEntangling Expressivity&lt;br&gt;• Parameter-Efficient Learning&lt;br&gt;• Noise-Robust Quantum Features&lt;br&gt;• Natural for Correlated Patterns&lt;br&gt;• Non-local correlations via CNOT&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#E65100&quot;&gt;Quantum Advantage Hypothesis&lt;/b&gt;&lt;br&gt;&lt;i&gt;Data points non-separable in ℝ⁸&lt;br&gt;may become linearly separable in&lt;br&gt;ℂ²⁵⁶ induced Hilbert space.&lt;br&gt;(Schuld et al., 2020; Havlíček&lt;br&gt;et al., 2019; Abbas et al., 2021)&lt;/i&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="200" width="235" x="2588" y="460" as="geometry" />
        </mxCell>
        <mxCell id="s4_qubit_panel" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF9800;arcSize=4;strokeWidth=1.5;" value="" vertex="1">
          <mxGeometry height="160" width="1590" x="700" y="710" as="geometry" />
        </mxCell>
