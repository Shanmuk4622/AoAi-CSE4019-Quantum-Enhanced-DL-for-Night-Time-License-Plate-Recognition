        <mxCell id="cmp_r8b" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FFAB91;" value="&lt;font style=&quot;font-size:8px;color:#2E7D32&quot;&gt;&lt;b&gt;92.5%&lt;/b&gt;&lt;/font&gt;" vertex="1">
