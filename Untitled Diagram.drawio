        <mxCell id="s4_tanh" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF8F00;strokeColor=#E65100;fontColor=#FFFFFF;fontSize=11;arcSize=8;strokeWidth=2;" value="&lt;b style=&quot;font-size:14px&quot;&gt;Tanh&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;σ(x) = (e&lt;sup&gt;x&lt;/sup&gt; − e&lt;sup&gt;−x&lt;/sup&gt;) / (e&lt;sup&gt;x&lt;/sup&gt; + e&lt;sup&gt;−x&lt;/sup&gt;)&lt;br&gt;&lt;br&gt;output ∈ (−1, +1)&lt;br&gt;&lt;br&gt;&lt;i style=&quot;color:#BF360C&quot;&gt;Mimics VQC output&lt;br&gt;range [−1, +1]&lt;/i&gt;&lt;br&gt;&lt;br&gt;No trainable params&lt;/font&gt;" vertex="1">
          <mxGeometry height="155" width="150" x="1134" y="704" as="geometry" />
        </mxCell>
        <mxCell id="s4_lin2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF6D00;strokeColor=#E65100;fontColor=#FFFFFF;fontSize=11;arcSize=8;strokeWidth=2;" value="&lt;b style=&quot;font-size:13px&quot;&gt;Linear&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;W₂ ∈ ℝ&lt;sup&gt;8×16&lt;/sup&gt;&lt;/b&gt;&lt;br&gt;+ bias b₂ ∈ ℝ&lt;sup&gt;8&lt;/sup&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;16 → 8&lt;/b&gt;&lt;br&gt;&lt;br&gt;Params: 16×8 + 8&lt;br&gt;= &lt;b&gt;136&lt;/b&gt;&lt;/font&gt;" vertex="1">
