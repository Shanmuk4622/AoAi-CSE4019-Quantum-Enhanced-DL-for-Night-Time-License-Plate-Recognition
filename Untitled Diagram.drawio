          <mxGeometry height="22" width="600" x="860" y="1160" as="geometry" />
        </mxCell>
        <mxCell id="train_text" parent="1" style="text;html=1;align=left;" value="&lt;font style=&quot;font-size:9px;color:#333&quot;&gt;• Dataset: &lt;b&gt;RodoSol-ALPR (100K samples)&lt;/b&gt;&lt;br&gt;• Split: 70%/15%/15% (train/val/test)&lt;br&gt;• Optimizer: Adam (β₁=0.9, β₂=0.999)&lt;br&gt;• LR: CosineAnnealing (η₀=1e-3)&lt;br&gt;• Batch size: 32 (batch: T4 GPU)&lt;br&gt;• Total epochs: &lt;b&gt;100&lt;/b&gt;&lt;br&gt;• Early stopping: patience=12&lt;br&gt;• Gradient clipping: max_norm=5.0&lt;br&gt;• Platform: Kaggle Dual Tesla T4 + HF Hub&lt;br&gt;• Quantum: PennyLane default.qubit (cuda:0)&lt;br&gt;• Classical: DataParallel (2× T4)&lt;br&gt;• Seed: 42 (reproducible splits)&lt;br&gt;• Per-epoch push to HuggingFace Hub&lt;br&gt;&amp;nbsp;&amp;nbsp;(survives 12h Kaggle session limit)&lt;/font&gt;" vertex="1">
          <mxGeometry height="165" width="570" x="875" y="1185" as="geometry" />
        </mxCell>
