        <mxCell id="perf_bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#BDBDBD;arcSize=4;strokeWidth=1.5;" value="" vertex="1">
          <mxGeometry height="200" width="820" x="20" y="1155" as="geometry" />
        </mxCell>
        <mxCell id="perf_title" parent="1" style="text;html=1;align=center;" value="&lt;font style=&quot;font-size:11px;color:#1B2A4A&quot;&gt;&lt;b&gt;Verified Performance Metrics (on NightALPR)&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="22" width="820" x="20" y="1160" as="geometry" />
        </mxCell>
        <mxCell id="perf_text" parent="1" style="text;html=1;align=left;" value="&lt;font style=&quot;font-size:9px;color:#333&quot;&gt;• Best Val CER: &lt;b&gt;1.586%&lt;/b&gt; (epoch 89)&lt;br&gt;• Val Accuracy (clean): &lt;b&gt;92.01%&lt;/b&gt;&lt;br&gt;• Val Accuracy (night): &lt;b&gt;87.93%&lt;/b&gt;&lt;br&gt;• Inference: &lt;b&gt;30.2 ms/image (simulated)&lt;/b&gt;&lt;br&gt;• Projected real QHW: &lt;b&gt;~2.2 ms/image&lt;/b&gt;&lt;br&gt;• 15× overhead solely from PennyLane&lt;br&gt;&amp;nbsp;&amp;nbsp;physical simulation of quantum circuits&lt;br&gt;&lt;br&gt;&lt;b style=&quot;color:#B71C1C&quot;&gt;Classical Baseline Comparison:&lt;/b&gt;&lt;br&gt;• CER: 1.330% (epoch 98) — Δ = +0.255%&lt;br&gt;• Accuracy: 92.5% — Δ = −0.5%&lt;br&gt;• Inference: 2.0 ms — 15.1× faster&lt;br&gt;• Gap attributable to simulation effects&lt;/font&gt;" vertex="1">
          <mxGeometry height="165" width="400" x="35" y="1185" as="geometry" />
        </mxCell>
        <mxCell id="perf_text2" parent="1" style="text;html=1;align=left;" value="&lt;font style=&quot;font-size:9px;color:#333&quot;&gt;&lt;b style=&quot;color:#283593&quot;&gt;Metric Breakdown (Table 8):&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Clean Test (15k plates):&lt;/b&gt;&lt;br&gt;Quantum CER 1.6% | WER 8.0% | Acc 92.0%&lt;br&gt;Classical CER 1.3% | WER 7.5% | Acc 92.5%&lt;br&gt;&lt;br&gt;&lt;b&gt;Night Test (γ∈[2.0,3.5], σ=0.05):&lt;/b&gt;&lt;br&gt;Quantum CER ≈2.5% | WER ≈11.5% | Acc ≈87.5%&lt;br&gt;Classical CER ≈2.2% | WER ≈10.5% | Acc ≈88.5%&lt;br&gt;&lt;br&gt;&lt;b&gt;Night degradation: 4–4.5%&lt;/b&gt; (vs 15–25%&lt;br&gt;for systems without Zero-DCE)&lt;/font&gt;" vertex="1">
          <mxGeometry height="165" width="380" x="445" y="1185" as="geometry" />
        </mxCell>
        <mxCell id="train_bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#BDBDBD;arcSize=4;strokeWidth=1.5;" value="" vertex="1">
          <mxGeometry height="200" width="600" x="860" y="1155" as="geometry" />
        </mxCell>
