        <mxCell id="s4_fc_title" parent="1" style="text;html=1;align=center;" value="&lt;font style=&quot;font-size:12px;color:#BF360C&quot;&gt;&lt;b&gt;Classical Replacement Block&lt;/b&gt;&amp;nbsp;&amp;nbsp;|&amp;nbsp;&amp;nbsp;y = W₂ · tanh(W₁ · x + b₁) + b₂&amp;nbsp;&amp;nbsp;|&amp;nbsp;&amp;nbsp;280 trainable params&lt;/font&gt;" vertex="1">
